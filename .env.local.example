# ─── Required for AI brief generation ────────────────────────────────────────
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── Required for live macro data ─────────────────────────────────────────────
# Free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ─── Optional: additional data sources ────────────────────────────────────────
# BLS (labor / CPI data, FRED covers this already)
BLS_API_KEY=

# BEA (GDP / PCE, FRED covers this already)
BEA_API_KEY=

# Alpha Vantage (equity price quotes)
# Free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# ─── Optional: Supabase persistence ───────────────────────────────────────────
# Without Supabase, the app uses localStorage for watchlist / tasks / archive.
# Create a free project at: https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
